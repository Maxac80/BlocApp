rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================
    // 🔐 HELPER FUNCTIONS
    // ============================================

    // Verifică dacă utilizatorul este autentificat
    function isAuthenticated() {
      return request.auth != null;
    }

    // Verifică dacă utilizatorul este proprietarul documentului
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Verifică dacă utilizatorul este super_admin sau master
    function isSuperAdmin() {
      let userRole = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
      return isAuthenticated() &&
        (userRole == 'super_admin' || userRole == 'master');
    }

    // Verifică dacă utilizatorul este owner al organizației
    function isOrgOwner(orgId) {
      return isAuthenticated() &&
        request.auth.uid in get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerIds;
    }

    // Verifică dacă utilizatorul este membru al organizației (owner sau membru)
    function isOrgMember(orgId) {
      return isAuthenticated() && (
        isOrgOwner(orgId) ||
        exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid))
      );
    }

    // Verifică dacă utilizatorul are rol specific în organizație
    function hasOrgRole(orgId, roles) {
      let membership = get(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)).data;
      return isAuthenticated() && membership.role in roles;
    }

    // Verifică dacă utilizatorul are acces la asociație (admin, owner, sau membru)
    function hasAssociationAccess(assocId) {
      let assoc = get(/databases/$(database)/documents/associations/$(assocId)).data;
      return isAuthenticated() && (
        assoc.adminId == request.auth.uid ||
        request.auth.uid in assoc.ownerIds ||
        exists(/databases/$(database)/documents/associations/$(assocId)/members/$(request.auth.uid)) ||
        isSuperAdmin()
      );
    }

    // Verifică dacă utilizatorul este admin al asociației
    // IMPORTANT: folosim exists() înainte de get().data pentru a evita erori
    // când member doc nu există (ex: la acceptare invitație)
    function isAssocAdmin(assocId) {
      let assoc = get(/databases/$(database)/documents/associations/$(assocId)).data;
      return assoc.adminId == request.auth.uid ||
        (exists(/databases/$(database)/documents/associations/$(assocId)/members/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/associations/$(assocId)/members/$(request.auth.uid)).data.role == 'assoc_admin');
    }

    // ============================================
    // 👤 USERS COLLECTION
    // ============================================
    match /users/{userId} {
      // Citire: propriul profil, super_admin, sau oricine autentificat (pentru member lookup)
      allow read: if isAuthenticated();

      // Creare: doar pentru propriul profil
      allow create: if isOwner(userId);

      // Update: propriul profil sau super_admin
      allow update: if isOwner(userId) || isSuperAdmin();

      // Delete: doar super_admin
      allow delete: if isSuperAdmin();
    }

    // ============================================
    // 🏢 ORGANIZATIONS COLLECTION
    // ============================================
    match /organizations/{orgId} {
      // Citire: oricine autentificat care e membru sau owner
      allow read: if isOrgMember(orgId) || isSuperAdmin();

      // Creare: oricine autentificat (devine owner)
      allow create: if isAuthenticated();

      // Update: doar owners sau super_admin
      allow update: if isOrgOwner(orgId) || isSuperAdmin();

      // Delete: doar super_admin (soft delete prin update în cod)
      allow delete: if isSuperAdmin();

      // Sub-colecția members
      match /members/{memberId} {
        // Citire: membrii organizației
        allow read: if isOrgMember(orgId) || isSuperAdmin();

        // Creare: owner sau admin al organizației
        allow create: if isOrgOwner(orgId) ||
          hasOrgRole(orgId, ['org_admin']) ||
          isSuperAdmin();

        // Update: owner sau admin al organizației
        allow update: if isOrgOwner(orgId) ||
          hasOrgRole(orgId, ['org_admin']) ||
          isSuperAdmin();

        // Delete: owner sau admin al organizației
        allow delete: if isOrgOwner(orgId) ||
          hasOrgRole(orgId, ['org_admin']) ||
          isSuperAdmin();
      }

      // Sub-colecția invitations
      match /invitations/{invitationId} {
        // Citire: oricine autentificat (pentru verificare token)
        allow read: if isAuthenticated();

        // Creare: owner sau admin al organizației
        allow create: if isOrgOwner(orgId) ||
          hasOrgRole(orgId, ['org_admin']) ||
          isSuperAdmin();

        // Update: owner sau admin, sau userul care acceptă invitația
        allow update: if isOrgOwner(orgId) ||
          hasOrgRole(orgId, ['org_admin']) ||
          isSuperAdmin() ||
          isAuthenticated(); // Pentru acceptare

        // Delete: owner sau admin al organizației
        allow delete: if isOrgOwner(orgId) ||
          hasOrgRole(orgId, ['org_admin']) ||
          isSuperAdmin();
      }
    }

    // ============================================
    // 🏠 ASSOCIATIONS COLLECTION
    // ============================================
    match /associations/{assocId} {
      // Citire: admin-ul asociației, membrii organizației părinte, sau super_admin
      allow read: if isAuthenticated();

      // Creare: oricine autentificat
      allow create: if isAuthenticated();

      // Update: admin-ul asociației sau super_admin
      allow update: if hasAssociationAccess(assocId) || isSuperAdmin();

      // Delete: doar super_admin
      allow delete: if isSuperAdmin();

      // Sub-colecția members (admini pot gestiona, toți membrii pot citi)
      match /members/{memberId} {
        allow read: if hasAssociationAccess(assocId) || isSuperAdmin();
        // isOwner PRIMUL - la acceptare invitație, member doc nu există încă,
        // deci isAssocAdmin ar face get() pe null și ar crasha toată regula
        allow create, update: if isOwner(memberId) ||
          isAssocAdmin(assocId) || isSuperAdmin();
        allow delete: if isAssocAdmin(assocId) || isSuperAdmin();
      }

      // Sub-colecția invitations (admini creează, oricine autentificat poate citi/accepta)
      match /invitations/{invitationId} {
        allow read: if isAuthenticated(); // oricine poate verifica un token
        allow create: if isAssocAdmin(assocId) || isSuperAdmin();
        allow update: if isAssocAdmin(assocId) || isSuperAdmin() ||
          isAuthenticated(); // user-ul care acceptă invitația
        allow delete: if isAssocAdmin(assocId) || isSuperAdmin();
      }

      // Alte sub-colecții asociație
      match /{subcollection}/{docId} {
        allow read, write: if hasAssociationAccess(assocId) || isSuperAdmin();
      }
    }

    // ============================================
    // 📋 ALTE COLECȚII (legacy support)
    // ============================================

    // Apartments
    match /apartments/{apartmentId} {
      allow read, write: if isAuthenticated();
    }

    // Blocs (legacy name)
    match /blocs/{blocId} {
      allow read, write: if isAuthenticated();
    }

    // Blocks (actual collection name used by code)
    match /blocks/{blockId} {
      allow read, write: if isAuthenticated();
    }

    // Stairs
    match /stairs/{stairId} {
      allow read, write: if isAuthenticated();
    }

    // Expenses
    match /expenses/{expenseId} {
      allow read, write: if isAuthenticated();
    }

    // Custom Expenses (fallback collection)
    match /customExpenses/{customExpenseId} {
      allow read, write: if isAuthenticated();
    }

    // Suppliers
    match /suppliers/{supplierId} {
      allow read, write: if isAuthenticated();
    }

    // Invoices
    match /invoices/{invoiceId} {
      allow read, write: if isAuthenticated();
    }

    // Sheets
    match /sheets/{sheetId} {
      allow read, write: if isAuthenticated();
    }

    // Payments
    match /payments/{paymentId} {
      allow read, write: if isAuthenticated();
    }

    // Incasari
    match /incasari/{incasareId} {
      allow read, write: if isAuthenticated();
    }

    // Owners
    match /owners/{ownerId} {
      allow read, write: if isAuthenticated();
    }

    // Audit Logs (root level)
    match /audit_logs/{logId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isSuperAdmin();
    }

    // Onboarding Progress (root level)
    match /onboarding_progress/{progressId} {
      allow read, write: if isAuthenticated();
    }

    // Login Attempts (rate limiting - pre-auth access needed)
    match /login_attempts/{email} {
      allow read, write: if true;
    }

    // ============================================
    // 🔒 CATCH-ALL REMOVED (was temporarily permissive)
    // All collections now have explicit rules above
    // ============================================
  }
}
